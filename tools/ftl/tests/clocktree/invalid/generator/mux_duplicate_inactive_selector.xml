<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="OSC" enable="always" dynamic="no">
      <description>fixed oscillator</description>
      <derived frequency="4000000U" />
    </clock>
    <clock point="MUXED" enable="always" dynamic="no">
      <description>mux with duplicate inactive selector</description>
      <mux name="MUXEDSEL">
        <input point="OSC" default="yes">
          <bits value="MUXEDSEL_OSC" />
        </input>
        <inactive value="MUXEDSEL_OSC" bits="0U" when="TRUE" />
      </mux>
    </clock>
  </clocks>
</clocktree>
