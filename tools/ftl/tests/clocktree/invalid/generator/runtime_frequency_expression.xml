<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <clocks>
    <clock point="HSI16" enable="always" dynamic="yes">
      <description>HSI16 clock</description>
      <derived frequency="16000000U" />
    </clock>
    <clock point="ICLK" enable="always" dynamic="no">
      <description>runtime-derived internal clock</description>
      <derived>
        <frequencies>
          <default value="(hal_lld_get_clock_point(TCLK_HSI16) / 256U)" />
        </frequencies>
      </derived>
    </clock>
  </clocks>
</clocktree>
