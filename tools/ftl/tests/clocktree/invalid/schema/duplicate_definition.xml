<clocktree>
  <settings>
    <prefixes clock_points="TCLK_" macros="TST_" cfgs="TST_CFG_" />
    <suffixes frequency="_FREQ" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <definitions>
      <define name="RCC_DUPLICATE" value="0" />
      <define name="RCC_DUPLICATE" value="1" />
    </definitions>
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
    </configs>
  </settings>
  <sources>
    <source point="OSC" enable="always" dynamic="no" frequency="16000000U">
      <description>root oscillator</description>
    </source>
  </sources>
  <clocks>
    <clock point="SYSCLK" enable="always" dynamic="no">
      <description>system clock mux</description>
      <mux name="SYSSEL">
        <input point="OSC" default="yes">
          <bits value="SYSSEL_OSC" />
        </input>
      </mux>
    </clock>
  </clocks>
</clocktree>
