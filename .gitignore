# ChibiOS generated build outputs.
# BUILDDIR / DEPDIR as set in the demo and test makefiles.
build/
.dep/

# doc/build holds tracked Doxygen sources, not build artifacts.
!/doc/build/

# Eclipse / ChibiStudio debug launch configs are per-user and are not
# versioned by default. The directories below are the intentional
# exceptions (their launch configs ship with the project).
*.launch
!tools/eclipse/**/*.launch
!demos/LPC21xx/RT-LPC214x-OLIMEX/debug/*.launch
!demos/RP/RT-RP2040-PICO/debug/*.launch
!demos/STM32/RT-STM32L552ZE-NUCLEO144/debug/*.launch
!demos/various/RT-ARM7-GENERIC/debug/*.launch
