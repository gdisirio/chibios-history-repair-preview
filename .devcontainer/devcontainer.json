{
  "name": "ChibiOS ARM Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "LANG": "C.UTF-8",
    "LC_ALL": "C.UTF-8",
    "LANGUAGE": "C.UTF-8",
    "PYTHONUTF8": "1"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.encoding": "utf8",
        "files.autoGuessEncoding": false
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools",
        "ms-python.python"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
