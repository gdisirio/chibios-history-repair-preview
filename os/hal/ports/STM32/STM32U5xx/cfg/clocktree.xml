<clocktree
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://www.chibios.org/xml/schema/clocks/clocktree.xsd">
  <settings>
    <prefixes clock_points="CLK_" macros="STM32_" cfgs="STM32_CFG_" />
    <suffixes frequency="_FREQ" clock="_CLOCK" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <enums>
      <enum name="RCC_ICSCR1_MSISRANGE" field="RCC_ICSCR1_MSISRANGE_Pos">
        <item name="RANGE0_48M" value="0U" />
        <item name="RANGE1_24M" value="1U" />
        <item name="RANGE2_16M" value="2U" />
        <item name="RANGE3_12M" value="3U" />
        <item name="RANGE4_4M" value="4U" />
        <item name="RANGE5_2M" value="5U" />
        <item name="RANGE6_1333K" value="6U" />
        <item name="RANGE7_1M" value="7U" />
        <item name="RANGE8_3072K" value="8U" />
        <item name="RANGE9_1536K" value="9U" />
        <item name="RANGE10_1024K" value="10U" />
        <item name="RANGE11_768K" value="11U" />
        <item name="RANGE12_400K" value="12U" />
        <item name="RANGE13_200K" value="13U" />
        <item name="RANGE14_133K" value="14U" />
        <item name="RANGE15_100K" value="15U" />
      </enum>
      <enum name="RCC_ICSCR1_MSIKRANGE" field="RCC_ICSCR1_MSIKRANGE_Pos">
        <item name="RANGE0_48M" value="0U" />
        <item name="RANGE1_24M" value="1U" />
        <item name="RANGE2_16M" value="2U" />
        <item name="RANGE3_12M" value="3U" />
        <item name="RANGE4_4M" value="4U" />
        <item name="RANGE5_2M" value="5U" />
        <item name="RANGE6_1333K" value="6U" />
        <item name="RANGE7_1M" value="7U" />
        <item name="RANGE8_3072K" value="8U" />
        <item name="RANGE9_1536K" value="9U" />
        <item name="RANGE10_1024K" value="10U" />
        <item name="RANGE11_768K" value="11U" />
        <item name="RANGE12_400K" value="12U" />
        <item name="RANGE13_200K" value="13U" />
        <item name="RANGE14_133K" value="14U" />
        <item name="RANGE15_100K" value="15U" />
      </enum>
      <enum name="RCC_ICSCR1_MSIBIAS" field="RCC_ICSCR1_MSIBIAS_Pos">
        <item name="CONTINUOUS" value="0U" />
        <item name="SAMPLING" value="1U" />
      </enum>
      <enum name="RCC_ICSCR1_MSIRGSEL" field="RCC_ICSCR1_MSIRGSEL_Pos">
        <item name="CSR" value="0U" />
        <item name="ICSCR1" value="1U" />
      </enum>
    </enums>
    <definitions>
      <define name="RCC_BDCR_LSIPREDIV_DIV1" value="0U" />
      <define name="RCC_BDCR_LSIPREDIV_DIV128" value="RCC_BDCR_LSIPREDIV" />
    </definitions>
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
      <config name="PWR_VOSR" type="set" default="PWR_VOSR_VOS_RANGE1"
              values="PWR_VOSR_VOS_RANGE1 PWR_VOSR_VOS_RANGE2 PWR_VOSR_VOS_RANGE3 PWR_VOSR_VOS_RANGE4">
        <description>Selects the core voltage scaling range.</description>
      </config>
      <config name="LSI_PREDIV" type="set"
              default="RCC_BDCR_LSIPREDIV_DIV1"
              values="RCC_BDCR_LSIPREDIV_DIV1 RCC_BDCR_LSIPREDIV_DIV128">
        <description>Selects the LSI oscillator output divider.</description>
      </config>
      <config name="MSIS_RANGE" type="set"
              default="RCC_ICSCR1_MSISRANGE_RANGE4_4M"
              values="RCC_ICSCR1_MSISRANGE_RANGE0_48M RCC_ICSCR1_MSISRANGE_RANGE1_24M RCC_ICSCR1_MSISRANGE_RANGE2_16M RCC_ICSCR1_MSISRANGE_RANGE3_12M RCC_ICSCR1_MSISRANGE_RANGE4_4M RCC_ICSCR1_MSISRANGE_RANGE5_2M RCC_ICSCR1_MSISRANGE_RANGE6_1333K RCC_ICSCR1_MSISRANGE_RANGE7_1M RCC_ICSCR1_MSISRANGE_RANGE8_3072K RCC_ICSCR1_MSISRANGE_RANGE9_1536K RCC_ICSCR1_MSISRANGE_RANGE10_1024K RCC_ICSCR1_MSISRANGE_RANGE11_768K RCC_ICSCR1_MSISRANGE_RANGE12_400K RCC_ICSCR1_MSISRANGE_RANGE13_200K RCC_ICSCR1_MSISRANGE_RANGE14_133K RCC_ICSCR1_MSISRANGE_RANGE15_100K">
        <description>Selects the MSIS frequency range.</description>
      </config>
      <config name="MSIK_RANGE" type="set"
              default="RCC_ICSCR1_MSIKRANGE_RANGE4_4M"
              values="RCC_ICSCR1_MSIKRANGE_RANGE0_48M RCC_ICSCR1_MSIKRANGE_RANGE1_24M RCC_ICSCR1_MSIKRANGE_RANGE2_16M RCC_ICSCR1_MSIKRANGE_RANGE3_12M RCC_ICSCR1_MSIKRANGE_RANGE4_4M RCC_ICSCR1_MSIKRANGE_RANGE5_2M RCC_ICSCR1_MSIKRANGE_RANGE6_1333K RCC_ICSCR1_MSIKRANGE_RANGE7_1M RCC_ICSCR1_MSIKRANGE_RANGE8_3072K RCC_ICSCR1_MSIKRANGE_RANGE9_1536K RCC_ICSCR1_MSIKRANGE_RANGE10_1024K RCC_ICSCR1_MSIKRANGE_RANGE11_768K RCC_ICSCR1_MSIKRANGE_RANGE12_400K RCC_ICSCR1_MSIKRANGE_RANGE13_200K RCC_ICSCR1_MSIKRANGE_RANGE14_133K RCC_ICSCR1_MSIKRANGE_RANGE15_100K">
        <description>Selects the MSIK frequency range.</description>
      </config>
      <config name="MSIBIAS" type="set"
              default="RCC_ICSCR1_MSIBIAS_CONTINUOUS"
              values="RCC_ICSCR1_MSIBIAS_CONTINUOUS RCC_ICSCR1_MSIBIAS_SAMPLING">
        <description>Selects the MSI bias mode.</description>
      </config>
    </configs>
    <derived-configs>
      <derived-config name="MSISRC_SEL" type="expression"
                      value="(STM32_CFG_MSIS_RANGE &amp; (12U &lt;&lt; RCC_ICSCR1_MSISRANGE_Pos))" />
      <derived-config name="MSISDIV_VALUE" type="expression"
                      value="((((STM32_CFG_MSIS_RANGE &gt;&gt; RCC_ICSCR1_MSISRANGE_Pos) &amp; 3U) + 1U))" />
      <derived-config name="MSIKRC_SEL" type="expression"
                      value="(STM32_CFG_MSIK_RANGE &amp; (12U &lt;&lt; RCC_ICSCR1_MSIKRANGE_Pos))" />
      <derived-config name="MSIKDIV_VALUE" type="expression"
                      value="((((STM32_CFG_MSIK_RANGE &gt;&gt; RCC_ICSCR1_MSIKRANGE_Pos) &amp; 3U) + 1U))" />
    </derived-configs>
    <states>
      <state name="vos1"
             when="STM32_CFG_PWR_VOSR == PWR_VOSR_VOS_RANGE1" />
      <state name="vos2"
             when="STM32_CFG_PWR_VOSR == PWR_VOSR_VOS_RANGE2" />
      <state name="vos3"
             when="STM32_CFG_PWR_VOSR == PWR_VOSR_VOS_RANGE3" />
      <state name="vos4"
             when="STM32_CFG_PWR_VOSR == PWR_VOSR_VOS_RANGE4" />
    </states>
    <limit-set>
      <limit name="HSECLK" min="yes" max="yes" />
      <limit name="LSECLK" min="yes" max="yes" />
      <limit name="PLLIN" min="yes" max="yes" />
      <limit name="PLLVCO" min="yes" max="yes" />
      <limit name="PLLP" min="yes" max="yes" />
      <limit name="PLLQ" min="yes" max="yes" />
      <limit name="PLLR" min="yes" max="yes" />
      <limit name="SYSCLK" min="no" max="yes" />
      <limit name="HCLK" min="no" max="yes" />
      <limit name="PCLK1" min="no" max="yes" />
      <limit name="PCLK2" min="no" max="yes" />
      <limit name="PCLK3" min="no" max="yes" />
      <limit name="ADCCLK" min="no" max="yes" />
    </limit-set>
    <limit-values>
      <state-values state="vos1">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="4000000" max="50000000" />
          <default min="4000000" max="50000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="5000" max="40000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="4000000" max="16000000" />
        <limit name="PLLVCO" min="128000000" max="544000000" />
        <limit name="PLLP" min="1000000" max="208000000" />
        <limit name="PLLQ" min="1000000" max="208000000" />
        <limit name="PLLR" min="1000000" max="208000000" />
        <limit name="SYSCLK" max="160000000" />
        <limit name="HCLK" max="160000000" />
        <limit name="PCLK1" max="160000000" />
        <limit name="PCLK2" max="160000000" />
        <limit name="PCLK3" max="160000000" />
        <limit name="ADCCLK" max="55000000" />
      </state-values>
      <state-values state="vos2">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="4000000" max="50000000" />
          <default min="4000000" max="50000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="5000" max="40000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="4000000" max="16000000" />
        <limit name="PLLVCO" min="128000000" max="544000000" />
        <limit name="PLLP" min="1000000" max="110000000" />
        <limit name="PLLQ" min="1000000" max="110000000" />
        <limit name="PLLR" min="1000000" max="110000000" />
        <limit name="SYSCLK" max="110000000" />
        <limit name="HCLK" max="110000000" />
        <limit name="PCLK1" max="110000000" />
        <limit name="PCLK2" max="110000000" />
        <limit name="PCLK3" max="110000000" />
        <limit name="ADCCLK" max="55000000" />
      </state-values>
      <state-values state="vos3">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="4000000" max="50000000" />
          <default min="4000000" max="50000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="5000" max="40000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="4000000" max="16000000" />
        <limit name="PLLVCO" min="128000000" max="330000000" />
        <limit name="PLLP" min="1000000" max="55000000" />
        <limit name="PLLQ" min="1000000" max="55000000" />
        <limit name="PLLR" min="1000000" max="55000000" />
        <limit name="SYSCLK" max="55000000" />
        <limit name="HCLK" max="55000000" />
        <limit name="PCLK1" max="55000000" />
        <limit name="PCLK2" max="55000000" />
        <limit name="PCLK3" max="55000000" />
        <limit name="ADCCLK" max="55000000" />
      </state-values>
      <state-values state="vos4">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="4000000" max="25000000" />
          <default min="4000000" max="25000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="5000" max="40000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="0" max="0" />
        <limit name="PLLVCO" min="0" max="0" />
        <limit name="PLLP" min="0" max="0" />
        <limit name="PLLQ" min="0" max="0" />
        <limit name="PLLR" min="0" max="0" />
        <limit name="SYSCLK" max="25000000" />
        <limit name="HCLK" max="25000000" />
        <limit name="PCLK1" max="25000000" />
        <limit name="PCLK2" max="25000000" />
        <limit name="PCLK3" max="25000000" />
        <limit name="ADCCLK" max="25000000" />
      </state-values>
    </limit-values>
  </settings>
  <sources>
    <source point="NONE" enable="never" dynamic="no" frequency="0U">
      <description>pseudo-clock for disabled sources</description>
    </source>
    <source point="HSI16" enable="manual" dynamic="yes" frequency="16000000U">
      <description>16 MHz high speed internal oscillator</description>
      <bits target="CR" enabled="(RCC_CR_HSION | RCC_CR_HSIKERON)" disabled="0U" />
    </source>
    <source point="HSI48" enable="manual" dynamic="yes" frequency="48000000U">
      <description>48 MHz high speed internal oscillator</description>
      <bits target="CR" enabled="RCC_CR_HSI48ON" disabled="0U" />
    </source>
    <source point="SHSI" enable="manual" dynamic="yes" frequency="48000000U">
      <description>48 MHz secure high speed internal oscillator</description>
      <bits target="CR" enabled="RCC_CR_SHSION" disabled="0U" />
    </source>
    <source point="HSE" enable="manual" dynamic="yes" frequency="STM32_HSECLK">
      <description>high speed external oscillator</description>
      <bits target="CR" enabled="(RCC_CR_HSEON | STM32_HSE_MODE_BITS)" disabled="0U" />
      <limits ref="HSECLK" />
    </source>
    <source point="LSE" enable="manual" dynamic="no" frequency="STM32_LSECLK">
      <description>low speed external oscillator</description>
      <bits target="BDCR" enabled="(RCC_BDCR_LSEON | STM32_LSE_MODE_BITS)" disabled="0U" />
      <limits ref="LSECLK" />
    </source>
    <source point="LSI" enable="manual" dynamic="no">
      <description>low speed internal oscillator</description>
      <bits target="BDCR" enabled="(RCC_BDCR_LSION | STM32_CFG_LSI_PREDIV)" disabled="0U" />
      <frequencies>
        <select>
          <when condition="STM32_CFG_LSI_PREDIV == RCC_BDCR_LSIPREDIV_DIV128"
                value="250U" />
          <otherwise value="32000U" />
        </select>
      </frequencies>
    </source>
    <source point="MSIRC0" enable="auto" dynamic="no" frequency="48000000U">
      <description>48 MHz internal MSI RC oscillator</description>
    </source>
    <source point="MSIRC1" enable="auto" dynamic="no" frequency="4000000U">
      <description>4 MHz internal MSI RC oscillator</description>
    </source>
    <source point="MSIRC2" enable="auto" dynamic="no" frequency="3072000U">
      <description>3.072 MHz internal MSI RC oscillator</description>
    </source>
    <source point="MSIRC3" enable="auto" dynamic="no" frequency="400000U">
      <description>400 kHz internal MSI RC oscillator</description>
    </source>
  </sources>
  <clocks>
    <clock point="MSISRC" enable="auto" dynamic="no">
      <description>MSIS internal RC selection</description>
      <mux name="MSISRC" field="RCC_ICSCR1_MSISRANGE" offset="28U"
           setting="STM32_DCFG_MSISRC_SEL">
        <input point="MSIRC0" encoding="0U" />
        <input point="MSIRC1" encoding="4U" default="yes" />
        <input point="MSIRC2" encoding="8U" />
        <input point="MSIRC3" encoding="12U" />
      </mux>
    </clock>
    <clock point="MSISDIV" enable="auto" dynamic="no">
      <description>MSIS range divider</description>
      <divider name="MSISDIV" input="MSISRC" field="RCC_ICSCR1_MSISRANGE"
               offset="28U" setting="STM32_DCFG_MSISDIV_VALUE">
        <choices default="1">
          <choice item="DIV1" value="1" encoding="0U" />
          <choice item="DIV2" value="2" encoding="1U" />
          <choice item="DIV3" value="3" encoding="2U" />
          <choice item="DIV4" value="4" encoding="3U" />
        </choices>
      </divider>
    </clock>
    <clock point="MSIS" enable="auto" dynamic="yes">
      <description>MSI system oscillator</description>
      <bits target="CR" enabled="RCC_CR_MSISON" disabled="0U" />
      <bits target="ICSCR1" enabled="(RCC_ICSCR1_MSIRGSEL_ICSCR1 | STM32_CFG_MSIBIAS)" disabled="0U" />
      <derived input="MSISDIV" frequency="%I%" />
    </clock>
    <clock point="MSIKRC" enable="auto" dynamic="no">
      <description>MSIK internal RC selection</description>
      <mux name="MSIKRC" field="RCC_ICSCR1_MSIKRANGE" offset="24U"
           setting="STM32_DCFG_MSIKRC_SEL">
        <input point="MSIRC0" encoding="0U" />
        <input point="MSIRC1" encoding="4U" default="yes" />
        <input point="MSIRC2" encoding="8U" />
        <input point="MSIRC3" encoding="12U" />
      </mux>
    </clock>
    <clock point="MSIKDIV" enable="auto" dynamic="no">
      <description>MSIK range divider</description>
      <divider name="MSIKDIV" input="MSIKRC" field="RCC_ICSCR1_MSIKRANGE"
               offset="24U" setting="STM32_DCFG_MSIKDIV_VALUE">
        <choices default="1">
          <choice item="DIV1" value="1" encoding="0U" />
          <choice item="DIV2" value="2" encoding="1U" />
          <choice item="DIV3" value="3" encoding="2U" />
          <choice item="DIV4" value="4" encoding="3U" />
        </choices>
      </divider>
    </clock>
    <clock point="MSIK" enable="auto" dynamic="yes">
      <description>MSI kernel oscillator</description>
      <bits target="CR" enabled="RCC_CR_MSIKON" disabled="0U" />
      <bits target="ICSCR1" enabled="(RCC_ICSCR1_MSIRGSEL_ICSCR1 | STM32_CFG_MSIBIAS)" disabled="0U" />
      <derived input="MSIKDIV" frequency="%I%" />
    </clock>
    <clock point="SYSCLK" enable="always" dynamic="yes">
      <description>system clock</description>
      <limits ref="SYSCLK" />
      <mux name="SW">
        <input point="MSIS" default="yes">
          <bits value="RCC_CFGR1_SW_MSIS" />
        </input>
        <input point="HSI16">
          <bits value="RCC_CFGR1_SW_HSI16" />
        </input>
        <input point="HSE">
          <bits value="RCC_CFGR1_SW_HSE" />
        </input>
      </mux>
    </clock>
  </clocks>
</clocktree>
